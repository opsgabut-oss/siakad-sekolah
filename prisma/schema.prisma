datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  GURU
  GURU_BK
  KEPALA_SEKOLAH
  SISWA
  ORANG_TUA
}

enum StatusAbsensi {
  HADIR
  IZIN
  SAKIT
  ALPA
}

enum Hari {
  SENIN
  SELASA
  RABU
  KAMIS
  JUMAT
  SABTU
}

enum JenisNilai {
  TUGAS
  UTS
  UAS
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  guru      Guru?
  siswa     Siswa?   @relation("SiswaUser")
  orangTua  Siswa?   @relation("OrangTuaUser")
}

model TahunAjaran {
  id      String   @id @default(uuid())
  tahun   String   // e.g. "2025/2026"
  aktif   Boolean  @default(false)
  kelas   Kelas[]
}

model Kelas {
  id            String            @id @default(uuid())
  nama          String            // e.g. "Kelas 10-A"
  tahunAjaranId String
  tahunAjaran   TahunAjaran       @relation(fields: [tahunAjaranId], references: [id], onDelete: Cascade)
  siswa         Siswa[]
  jadwal        JadwalPelajaran[]
  
  // Wali Kelas Relation
  waliKelasId   String?           @unique
  waliKelas     Guru?             @relation(fields: [waliKelasId], references: [id], name: "WaliKelas", onDelete: SetNull)
  
  jurnalHarian  JurnalHarian[]
}

model Guru {
  id       String            @id @default(uuid())
  nuptk    String            @unique // 16 digit
  nama     String
  kontak   String
  userId   String?           @unique
  user     User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  absensi  Absensi[]
  jadwal   JadwalPelajaran[]
  
  kelasWali Kelas?           @relation("WaliKelas")
  jurnalHarian JurnalHarian[]
}

model Siswa {
  id             String    @id @default(uuid())
  nisn           String    @unique // 10 digit
  nama           String
  kelasId        String
  kelas          Kelas     @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  kontakOrangTua String
  tanggalLahir   DateTime? @db.Date
  
  userId         String?   @unique
  user           User?     @relation(fields: [userId], references: [id], name: "SiswaUser", onDelete: SetNull)
  
  orangTuaUserId String?   @unique
  orangTuaUser   User?     @relation(fields: [orangTuaUserId], references: [id], name: "OrangTuaUser", onDelete: SetNull)
  
  absensi        Absensi[]
  nilai          Nilai[]
  pelanggaran    PelanggaranSiswa[]
  catatanBK      CatatanBK[]
}

model Absensi {
  id            String        @id @default(uuid())
  siswaId       String
  siswa         Siswa         @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  tanggal       DateTime      @db.Date
  status        StatusAbsensi
  diabsenOlehId String
  diabsenOleh   Guru          @relation(fields: [diabsenOlehId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([siswaId, tanggal])
}

model MataPelajaran {
  id           String            @id @default(uuid())
  nama         String            // e.g. "Matematika"
  kode         String            @unique // e.g. "MTK"
  jadwal       JadwalPelajaran[]
  nilai        Nilai[]
  jurnalHarian JurnalHarian[]
}

model JadwalPelajaran {
  id              String        @id @default(uuid())
  kelasId         String
  kelas           Kelas         @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  mataPelajaranId String
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id], onDelete: Cascade)
  guruId          String
  guru            Guru          @relation(fields: [guruId], references: [id], onDelete: Cascade)
  hari            Hari
  jamMulai        String        // e.g. "07:30"
  jamSelesai      String        // e.g. "09:00"
}

model Nilai {
  id              String        @id @default(uuid())
  siswaId         String
  siswa         Siswa         @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  mataPelajaranId String
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id], onDelete: Cascade)
  jenis           JenisNilai
  nilai           Int           // 0-100
  keterangan      String?       // e.g. "Tugas 1 Aljabar"
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PelanggaranSiswa {
  id              String   @id @default(uuid())
  siswaId         String
  siswa           Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  tanggal         DateTime @db.Date
  namaPelanggaran String
  poin            Int
  keterangan      String   // AES-256 encrypted description
  dilaporkanOleh  String   // plain text name or role of reporter
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CatatanBK {
  id           String   @id @default(uuid())
  siswaId      String
  siswa        Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  tanggal      DateTime @db.Date
  kategori     String   // e.g. Bimbingan Pribadi, Bimbingan Belajar
  permasalahan String   // AES-256 encrypted permasalahan
  tindakan     String   // AES-256 encrypted tindakan / solusi
  status       String   // e.g. Selesai, Tindak Lanjut
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model JurnalHarian {
  id              String        @id @default(uuid())
  tanggal         DateTime      @db.Date
  kelasId         String
  kelas           Kelas         @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  guruId          String
  guru            Guru          @relation(fields: [guruId], references: [id], onDelete: Cascade)
  mataPelajaranId String
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id], onDelete: Cascade)
  materi          String
  catatan         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum JenisSurat {
  MASUK
  KELUAR
}

model ArsipSurat {
  id              String      @id @default(uuid())
  nomorSurat      String      @unique
  tanggalSurat    DateTime    @db.Date
  tanggalDiterima DateTime?   @db.Date
  pengirim        String
  penerima        String
  perihal         String
  jenis           JenisSurat
  tautanBerkas    String?
  keterangan      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model ProfilSekolah {
  id            String   @id @default("single-profile")
  pemerintah    String   @default("Pemerintah Kabupaten Pati")
  dinas         String   @default("Dinas Pendidikan dan Kebudayaan")
  namaSekolah   String   @default("SD Negeri Wedusan")
  npsn          String?  @default("20338123")
  alamat        String   @default("Jl. Puncel - Ngablak KM. 05 Desa Wedusan, Kec. Dukuhseti, Kab. Pati (59158)")
  telepon       String?  @default("081234567890")
  email         String?  @default("sdnwedusan@gmail.com")
  website       String?  @default("www.sdnwedusan.sch.id")
  logoUrl       String?  
  namaKepsek    String   @default("Sudarto, S.Pd")
  nipKepsek     String?  @default("197408122005011002")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

